# Sample .env file
# Copy this file to .env and fill in your values. NEVER COMMIT your .env !!!

# SEC EDGAR fair-access policy requires a User-Agent identifying you:
# https://www.sec.gov/os/accessing-edgar-data
# Sample setup as below:
SEC_USER_AGENT="YourProjectName your.email@example.com"

# Hugging Face model used for sentence-level sentiment
SENTIMENT_MODEL=ProsusAI/finbert

# LLM provider for the executive summary. Set the API key for ONE provider.
# Priority if several are set: Gemini > Anthropic > OpenAI.
# Leave all keys empty to run in mock mode (summary built from FinBERT
# evidence instead of an LLM — the app remains fully functional).

# Option 1 — Google Gemini (free tier, recommended)
#   Get a key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Option 2 — Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Option 3 — OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Pre-defined maximum sentiment analysis sentences per section
# Default = 300
MAX_SENTENCES_PER_SECTION=
